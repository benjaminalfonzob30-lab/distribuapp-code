<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_menu.xml — Layout del menú principal.
    Permite calcular el costo de despacho e ingresar monto y distancia.
    Muestra también la temperatura del congelador del camión en tiempo real.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Saludo al usuario autenticado -->
        <TextView
            android:id="@+id/tvBienvenida"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Bienvenido/a"
            android:textColor="#1A237E"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- ─── Tarjeta: Temperatura del congelador ──────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Estado del Congelador"
            android:textColor="#424242"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Muestra temperatura en tiempo real desde Firebase -->
        <TextView
            android:id="@+id/tvTemperatura"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:padding="14dp"
            android:text="Cargando temperatura..."
            android:textColor="#424242"
            android:textSize="15sp" />

        <!-- ─── Tarjeta: Calculadora de despacho ─────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Calcular Costo de Despacho"
            android:textColor="#424242"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Tabla de referencia de tarifas -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#E8EAF6"
            android:padding="12dp"
            android:text="• Compra ≥ $50.000 y ≤ 20 km → GRATIS\n• Compra $25.000–$49.999 → $150/km\n• Compra &lt; $25.000 → $300/km"
            android:textColor="#3949AB"
            android:textSize="13sp" />

        <!-- Campo: Monto total de la compra -->
        <EditText
            android:id="@+id/etMonto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Monto total de la compra ($)"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:textSize="15sp" />

        <!-- Campo: Distancia en kilómetros -->
        <EditText
            android:id="@+id/etKilometros"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Distancia al domicilio (km)"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:textSize="15sp" />

        <!-- Botón calcular -->
        <Button
            android:id="@+id/btnCalcular"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#1A237E"
            android:padding="14dp"
            android:text="Calcular Despacho"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Resultado del cálculo -->
        <TextView
            android:id="@+id/tvResultadoDespacho"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:gravity="center"
            android:minHeight="60dp"
            android:padding="16dp"
            android:text="El resultado aparecerá aquí"
            android:textColor="#424242"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Botón cerrar sesión -->
        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#B71C1C"
            android:padding="12dp"
            android:text="Cerrar Sesión"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>

</ScrollView>
